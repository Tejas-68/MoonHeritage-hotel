# Copy this file to frontend/.env.local for local development
# Copy relevant vars to Vercel Environment Variables for production

# ── Backend API URL ───────────────────────────────────────────────────
# For local dev: leave empty (Vite proxy handles /api → localhost:8081)
# VITE_API_URL=

# For production Vercel deploy: set to your Render backend URL
# VITE_API_URL=https://moonheritage-backend.onrender.com/api
